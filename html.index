<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>DocuCloud — Sistem Pengarsipan Dokumen</title>
<script src="https://cdn.tailwindcss.com"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
  * { font-family: 'Inter', sans-serif; }
  [x-cloak] { display: none !important; }
  .scrollbar::-webkit-scrollbar { width: 6px; height: 6px; }
  .scrollbar::-webkit-scrollbar-thumb { background: rgba(148,163,184,.4); border-radius: 10px; }
  .scrollbar::-webkit-scrollbar-thumb:hover { background: rgba(148,163,184,.7); }
  .glass { backdrop-filter: blur(16px); background: rgba(255,255,255,.7); }
  .dark .glass { background: rgba(15,23,42,.7); }
  .gradient-bg { background: linear-gradient(135deg,#667eea 0%,#764ba2 100%); }
  .file-card:hover { transform: translateY(-4px); }
  .file-card { transition: all .25s ease; }
  .fade-in { animation: fadeIn .4s ease; }
  @keyframes fadeIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
  .pulse-dot { animation: pulse 2s infinite; }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
</style>
</head>
<body class="bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-200"
      x-data="docuCloud()" x-init="init()" x-cloak
      :class="{'dark': darkMode}">

<div class="flex h-screen overflow-hidden">

  <!-- SIDEBAR -->
  <aside :class="sidebarOpen ? 'w-64' : 'w-20'" class="transition-all duration-300 bg-white dark:bg-slate-900 border-r border-slate-200 dark:border-slate-800 flex flex-col">
    <div class="h-16 flex items-center px-5 border-b border-slate-200 dark:border-slate-800">
      <div class="w-10 h-10 rounded-xl gradient-bg flex items-center justify-center flex-shrink-0">
        <i data-lucide="cloud-cog" class="w-6 h-6 text-white"></i>
      </div>
      <div x-show="sidebarOpen" class="ml-3 fade-in">
        <h1 class="font-bold text-lg">DocuCloud</h1>
        <p class="text-xs text-slate-500">v2.4.1</p>
      </div>
    </div>

    <nav class="flex-1 py-4 px-3 overflow-y-auto scrollbar">
      <p x-show="sidebarOpen" class="text-xs uppercase text-slate-400 font-semibold px-3 mb-2">Menu Utama</p>
      <template x-for="item in menu" :key="item.id">
        <button @click="activeMenu = item.id"
                :class="activeMenu === item.id ? 'bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400' : 'text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800'"
                class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg mb-1 transition">
          <i :data-lucide="item.icon" class="w-5 h-5 flex-shrink-0"></i>
          <span x-show="sidebarOpen" x-text="item.label" class="text-sm font-medium"></span>
          <span x-show="sidebarOpen && item.badge" x-text="item.badge" class="ml-auto text-xs bg-red-500 text-white rounded-full px-2 py-0.5"></span>
        </button>
      </template>

      <p x-show="sidebarOpen" class="text-xs uppercase text-slate-400 font-semibold px-3 mt-6 mb-2">Kategori</p>
      <template x-for="cat in categories" :key="cat.name">
        <button @click="filterCategory = cat.name; activeMenu = 'files'"
                class="w-full flex items-center gap-3 px-3 py-2 rounded-lg text-sm text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800">
          <span class="w-2 h-2 rounded-full flex-shrink-0" :style="`background:${cat.color}`"></span>
          <span x-show="sidebarOpen" x-text="cat.name"></span>
          <span x-show="sidebarOpen" x-text="cat.count" class="ml-auto text-xs text-slate-400"></span>
        </button>
      </template>
    </nav>

    <!-- Storage Widget -->
    <div class="p-3 border-t border-slate-200 dark:border-slate-800">
      <div x-show="sidebarOpen" class="bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl p-4 text-white">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-medium opacity-90">Penyimpanan</span>
          <i data-lucide="hard-drive" class="w-4 h-4"></i>
        </div>
        <p class="text-sm font-semibold"><span x-text="usedStorage"></span> / 15 GB</p>
        <div class="w-full bg-white/20 rounded-full h-1.5 mt-2">
          <div class="bg-white h-1.5 rounded-full" :style="`width:${storagePercent}%`"></div>
        </div>
        <button class="mt-3 text-xs bg-white/20 hover:bg-white/30 w-full py-1.5 rounded-lg">Upgrade Plan</button>
      </div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <div class="flex-1 flex flex-col overflow-hidden">

    <!-- TOPBAR -->
    <header class="h-16 glass border-b border-slate-200 dark:border-slate-800 flex items-center px-6 gap-4">
      <button @click="sidebarOpen = !sidebarOpen" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
        <i data-lucide="menu" class="w-5 h-5"></i>
      </button>

      <div class="flex-1 max-w-xl relative">
        <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-slate-400"></i>
        <input x-model="searchQuery" @input="filterFiles()" type="text" placeholder="Cari dokumen, folder, tag..."
               class="w-full pl-10 pr-4 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
      </div>

      <div class="flex items-center gap-2">
        <button @click="connectDrive()" class="hidden md:flex items-center gap-2 px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm hover:bg-slate-50 dark:hover:bg-slate-700">
          <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
          <span x-text="driveConnected ? 'Drive Terhubung' : 'Hubungkan Drive'"></span>
          <span :class="driveConnected ? 'bg-green-500' : 'bg-slate-400'" class="w-2 h-2 rounded-full pulse-dot"></span>
        </button>

        <button @click="darkMode = !darkMode" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg">
          <i :data-lucide="darkMode ? 'sun' : 'moon'" class="w-5 h-5"></i>
        </button>
        <button class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg relative">
          <i data-lucide="bell" class="w-5 h-5"></i>
          <span class="absolute top-1 right-1 w-2 h-2 bg-red-500 rounded-full"></span>
        </button>
        <div class="w-9 h-9 rounded-full gradient-bg flex items-center justify-center text-white font-semibold cursor-pointer">A</div>
      </div>
    </header>

    <!-- CONTENT AREA -->
    <main class="flex-1 overflow-y-auto scrollbar p-6">

      <!-- Dashboard View -->
      <div x-show="activeMenu === 'dashboard'" class="fade-in">
        <div class="mb-6">
          <h2 class="text-2xl font-bold">Selamat datang, Admin 👋</h2>
          <p class="text-slate-500 text-sm">Kelola seluruh dokumen perusahaan dalam satu tempat.</p>
        </div>

        <!-- Stats Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
          <template x-for="s in stats" :key="s.label">
            <div class="bg-white dark:bg-slate-900 rounded-xl p-5 border border-slate-200 dark:border-slate-800">
              <div class="flex items-center justify-between mb-3">
                <div class="w-10 h-10 rounded-lg flex items-center justify-center" :style="`background:${s.bg}`">
                  <i :data-lucide="s.icon" class="w-5 h-5" :style="`color:${s.color}`"></i>
                </div>
                <span :class="s.trend > 0 ? 'text-green-500' : 'text-red-500'" class="text-xs font-semibold flex items-center gap-1">
                  <i :data-lucide="s.trend > 0 ? 'trending-up' : 'trending-down'" class="w-3 h-3"></i>
                  <span x-text="Math.abs(s.trend)+'%'"></span>
                </span>
              </div>
              <p class="text-2xl font-bold" x-text="s.value"></p>
              <p class="text-xs text-slate-500 mt-1" x-text="s.label"></p>
            </div>
          </template>
        </div>

        <div class="grid lg:grid-cols-3 gap-6">
          <!-- Activity Chart -->
          <div class="lg:col-span-2 bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800">
            <div class="flex justify-between items-center mb-5">
              <h3 class="font-semibold">Aktivitas Dokumen</h3>
              <select class="text-xs bg-slate-100 dark:bg-slate-800 rounded-lg px-3 py-1.5">
                <option>7 Hari Terakhir</option><option>30 Hari</option><option>Tahun ini</option>
              </select>
            </div>
            <div class="flex items-end gap-3 h-48">
              <template x-for="(v,i) in chart" :key="i">
                <div class="flex-1 flex flex-col items-center gap-2">
                  <div class="w-full bg-indigo-500/20 rounded-t-lg relative" :style="`height:${v*100}%`">
                    <div class="absolute bottom-0 w-full bg-gradient-to-t from-indigo-600 to-purple-500 rounded-t-lg" :style="`height:${v*100}%`"></div>
                  </div>
                  <span class="text-xs text-slate-500" x-text="['Sen','Sel','Rab','Kam','Jum','Sab','Min'][i]"></span>
                </div>
              </template>
            </div>
          </div>

          <!-- Recent Activity -->
          <div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800">
            <h3 class="font-semibold mb-4">Aktivitas Terkini</h3>
            <div class="space-y-4">
              <template x-for="a in activities" :key="a.id">
                <div class="flex gap-3">
                  <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" :style="`background:${a.bg}`">
                    <i :data-lucide="a.icon" class="w-4 h-4" :style="`color:${a.color}`"></i>
                  </div>
                  <div class="flex-1 min-w-0">
                    <p class="text-sm truncate"><span class="font-medium" x-text="a.user"></span> <span x-text="a.action"></span></p>
                    <p class="text-xs text-slate-500 truncate" x-text="a.file"></p>
                    <p class="text-xs text-slate-400 mt-1" x-text="a.time"></p>
                  </div>
                </div>
              </template>
            </div>
          </div>
        </div>
      </div>

      <!-- Files View -->
      <div x-show="activeMenu === 'files'" class="fade-in">
        <div class="flex items-center justify-between mb-6">
          <div>
            <h2 class="text-2xl font-bold">File Saya</h2>
            <div class="flex items-center gap-2 text-sm text-slate-500 mt-1">
              <span>Root</span>
              <template x-for="f in breadcrumbs" :key="f">
                <span class="flex items-center gap-2"><i data-lucide="chevron-right" class="w-3 h-3"></i><span x-text="f"></span></template>
              </template>
            </div>
          </div>
          <div class="flex gap-2">
            <button @click="showNewFolder = true" class="px-4 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-sm flex items-center gap-2 hover:bg-slate-50">
              <i data-lucide="folder-plus" class="w-4 h-4"></i> Folder Baru
            </button>
            <button @click="showUpload = true" class="px-4 py-2 gradient-bg text-white rounded-lg text-sm flex items-center gap-2 hover:opacity-90">
              <i data-lucide="upload-cloud" class="w-4 h-4"></i> Upload
            </button>
          </div>
        </div>

        <!-- Filters -->
        <div class="flex items-center gap-3 mb-4 flex-wrap">
          <template x-for="f in ['Semua','Dokumen','Gambar','PDF','Spreadsheet']" :key="f">
            <button @click="fileType = f" :class="fileType===f ? 'bg-indigo-600 text-white' : 'bg-white dark:bg-slate-800'" class="px-4 py-1.5 rounded-lg text-xs font-medium border border-slate-200 dark:border-slate-700">
              <span x-text="f"></span>
            </button>
          </template>
          <div class="ml-auto flex gap-1 bg-white dark:bg-slate-800 rounded-lg p-1 border border-slate-200 dark:border-slate-700">
            <button @click="viewMode='grid'" :class="viewMode==='grid' ? 'bg-indigo-600 text-white' : ''" class="p-1.5 rounded"><i data-lucide="layout-grid" class="w-4 h-4"></i></button>
            <button @click="viewMode='list'" :class="viewMode==='list' ? 'bg-indigo-600 text-white' : ''" class="p-1.5 rounded"><i data-lucide="list" class="w-4 h-4"></i></button>
          </div>
        </div>

        <!-- Grid View -->
        <div x-show="viewMode==='grid'" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
          <template x-for="file in filteredFiles" :key="file.id">
            <div @click="openFile(file)" class="file-card bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 p-4 cursor-pointer hover:shadow-lg hover:border-indigo-300">
              <div class="aspect-square rounded-lg flex items-center justify-center mb-3" :style="`background:${file.color}20`">
                <i :data-lucide="file.icon" class="w-12 h-12" :style="`color:${file.color}`"></i>
              </div>
              <p class="text-sm font-medium truncate" x-text="file.name"></p>
              <div class="flex items-center justify-between mt-2">
                <span class="text-xs text-slate-500" x-text="file.size"></span>
                <span class="text-xs text-slate-400" x-text="file.date"></span>
              </div>
              <div class="flex items-center gap-1 mt-2">
                <span class="w-1.5 h-1.5 rounded-full" :style="`background:${catColor(file.category)}`"></span>
                <span class="text-xs text-slate-500" x-text="file.category"></span>
              </div>
            </div>
          </template>
        </div>

        <!-- List View -->
        <div x-show="viewMode==='list'" class="bg-white dark:bg-slate-900 rounded-xl border border-slate-200 dark:border-slate-800 overflow-hidden">
          <table class="w-full text-sm">
            <thead class="bg-slate-50 dark:bg-slate-800 text-xs text-slate-500 uppercase">
              <tr>
                <th class="text-left px-4 py-3">Nama</th>
                <th class="text-left px-4 py-3">Kategori</th>
                <th class="text-left px-4 py-3">Ukuran</th>
                <th class="text-left px-4 py-3">Dimodifikasi</th>
                <th class="text-right px-4 py-3">Aksi</th>
              </tr>
            </thead>
            <tbody>
              <template x-for="file in filteredFiles" :key="file.id">
                <tr class="border-t border-slate-100 dark:border-slate-800 hover:bg-slate-50 dark:hover:bg-slate-800/50">
                  <td class="px-4 py-3 flex items-center gap-3">
                    <i :data-lucide="file.icon" class="w-5 h-5" :style="`color:${file.color}`"></i>
                    <span x-text="file.name" class="font-medium"></span>
                  </td>
                  <td class="px-4 py-3"><span x-text="file.category" class="text-xs"></span></td>
                  <td class="px-4 py-3 text-slate-500" x-text="file.size"></td>
                  <td class="px-4 py-3 text-slate-500" x-text="file.date"></td>
                  <td class="px-4 py-3 text-right">
                    <button @click.stop="downloadFile(file)" class="p-1.5 hover:bg-slate-200 dark:hover:bg-slate-700 rounded"><i data-lucide="download" class="w-4 h-4"></i></button>
                    <button @click.stop="shareFile(file)" class="p-1.5 hover:bg-slate-200 dark:hover:bg-slate-700 rounded"><i data-lucide="share-2" class="w-4 h-4"></i></button>
                    <button @click.stop="deleteFile(file)" class="p-1.5 hover:bg-red-100 text-red-500 rounded"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                  </td>
                </tr>
              </template>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Shared / Trash / Settings Views (simple placeholders) -->
      <div x-show="['shared','trash','settings'].includes(activeMenu)" class="fade-in">
        <h2 class="text-2xl font-bold mb-4 capitalize" x-text="menu.find(m=>m.id===activeMenu)?.label"></h2>
        <div class="bg-white dark:bg-slate-900 rounded-xl p-8 border border-slate-200 dark:border-slate-800 text-center">
          <i data-lucide="package-open" class="w-16 h-16 mx-auto text-slate-300"></i>
          <p class="mt-4 text-slate-500">Modul ini siap dikembangkan lebih lanjut.</p>
        </div>
      </div>
    </main>
  </div>
</div>

<!-- UPLOAD MODAL -->
<div x-show="showUpload" x-transition class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div @click.away="showUpload=false" class="bg-white dark:bg-slate-900 rounded-2xl w-full max-w-lg p-6">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-lg font-bold">Upload Dokumen</h3>
      <button @click="showUpload=false"><i data-lucide="x" class="w-5 h-5"></i></button>
    </div>
    <div class="border-2 border-dashed border-slate-300 dark:border-slate-700 rounded-xl p-10 text-center">
      <i data-lucide="cloud-upload" class="w-12 h-12 mx-auto text-indigo-500 mb-3"></i>
      <p class="font-medium">Drag & drop file di sini</p>
      <p class="text-xs text-slate-500 mb-4">atau klik untuk memilih (Max 100MB)</p>
      <input type="file" multiple class="hidden" id="fileInput" @change="handleUpload($event)">
      <button onclick="document.getElementById('fileInput').click()" class="px-4 py-2 gradient-bg text-white rounded-lg text-sm">Pilih File</button>
    </div>
    <div class="mt-4">
      <label class="text-sm font-medium">Kategori</label>
      <select x-model="uploadCategory" class="w-full mt-1 px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm">
        <template x-for="c in categories" :key="c.name"><option x-text="c.name"></option></template>
      </select>
    </div>
    <div class="flex gap-2 mt-5">
      <button @click="uploadToDrive()" class="flex-1 py-2 bg-white border border-slate-200 rounded-lg text-sm flex items-center justify-center gap-2">
        <svg class="w-4 h-4" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/></svg>
        Upload ke Drive
      </button>
      <button @click="uploadLocal()" class="flex-1 py-2 gradient-bg text-white rounded-lg text-sm">Upload Lokal</button>
    </div>
  </div>
</div>

<!-- NEW FOLDER MODAL -->
<div x-show="showNewFolder" x-transition class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4">
  <div @click.away="showNewFolder=false" class="bg-white dark:bg-slate-900 rounded-2xl w-full max-w-md p-6">
    <h3 class="text-lg font-bold mb-4">Folder Baru</h3>
    <input x-model="newFolderName" type="text" placeholder="Nama folder..." class="w-full px-3 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500">
    <div class="flex gap-2 mt-4">
      <button @click="showNewFolder=false" class="flex-1 py-2 bg-slate-100 dark:bg-slate-800 rounded-lg text-sm">Batal</button>
      <button @click="createFolder()" class="flex-1 py-2 gradient-bg text-white rounded-lg text-sm">Buat</button>
    </div>
  </div>
</div>

<!-- FILE PREVIEW MODAL -->
<div x-show="previewFile" x-transition class="fixed inset-0 bg-black/70 z-50 flex items-center justify-center p-4">
  <div @click.away="previewFile=null" class="bg-white dark:bg-slate-900 rounded-2xl w-full max-w-3xl max-h-[90vh] overflow-hidden flex flex-col">
    <div class="flex justify-between items-center p-4 border-b border-slate-200 dark:border-slate-800">
      <div>
        <h3 class="font-bold" x-text="previewFile?.name"></h3>
        <p class="text-xs text-slate-500" x-text="`${previewFile?.size} • ${previewFile?.date}`"></p>
      </div>
      <div class="flex gap-1">
        <button @click="downloadFile(previewFile)" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg"><i data-lucide="download" class="w-4 h-4"></i></button>
        <button @click="shareFile(previewFile)" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg"><i data-lucide="share-2" class="w-4 h-4"></i></button>
        <button @click="previewFile=null" class="p-2 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg"><i data-lucide="x" class="w-4 h-4"></i></button>
      </div>
    </div>
    <div class="flex-1 overflow-auto p-6 flex items-center justify-center bg-slate-50 dark:bg-slate-950">
      <div class="text-center">
        <i :data-lucide="previewFile?.icon" class="w-24 h-24 mx-auto mb-4" :style="`color:${previewFile?.color}`"></i>
        <p class="text-slate-500">Preview file: <span class="font-medium" x-text="previewFile?.name"></span></p>
        <p class="text-xs text-slate-400 mt-2">Integrasi Google Drive Viewer akan muncul di sini</p>
      </div>
    </div>
  </div>
</div>

<!-- TOAST -->
<div x-show="toast.show" x-transition class="fixed bottom-6 right-6 z-50 bg-slate-900 text-white px-5 py-3 rounded-xl shadow-lg flex items-center gap-3">
  <i :data-lucide="toast.icon" class="w-5 h-5" :class="toast.type==='success' ? 'text-green-400' : 'text-red-400'"></i>
  <span x-text="toast.message" class="text-sm"></span>
</div>

<script>
function docuCloud() {
  return {
    sidebarOpen: true,
    darkMode: false,
    activeMenu: 'dashboard',
    searchQuery: '',
    fileType: 'Semua',
    viewMode: 'grid',
    filterCategory: '',
    driveConnected: false,
    showUpload: false,
    showNewFolder: false,
    newFolderName: '',
    uploadCategory: 'Hukum',
    previewFile: null,
    breadcrumbs: [],
    usedStorage: '8.4 GB',
    storagePercent: 56,
    toast: { show: false, message: '', type: 'success', icon: 'check-circle' },

    menu: [
      {id:'dashboard', label:'Dashboard', icon:'layout-dashboard'},
      {id:'files', label:'Semua File', icon:'folder', badge:'248'},
      {id:'shared', label:'Dibagikan', icon:'users', badge:'12'},
      {id:'trash', label:'Sampah', icon:'trash-2'},
      {id:'settings', label:'Pengaturan', icon:'settings'},
    ],

    categories: [
      {name:'Hukum', count:42, color:'#ef4444'},
      {name:'Keuangan', count:38, color:'#f59e0b'},
      {name:'HRD', count:27, color:'#10b981'},
      {name:'Marketing', count:56, color:'#3b82f6'},
      {name:'Operasional', count:85, color:'#8b5cf6'},
    ],

    stats: [
      {label:'Total Dokumen', value:'1,284', icon:'file-text', bg:'#dbeafe', color:'#2563eb', trend:12},
      {label:'Diupload Bulan Ini', value:'142', icon:'upload', bg:'#dcfce7', color:'#16a34a', trend:8},
      {label:'Dibagikan', value:'89', icon:'share-2', bg:'#fef3c7', color:'#d97706', trend:-3},
      {label:'Pengguna Aktif', value:'24', icon:'users', bg:'#ede9fe', color:'#7c3aed', trend:15},
    ],

    chart: [0.4, 0.7, 0.5, 0.9, 0.6, 0.3, 0.8],

    activities: [
      {id:1, user:'Budi S.', action:'mengupload', file:'Kontrak_Kerjasama_2026.pdf', icon:'upload', bg:'#dbeafe', color:'#2563eb', time:'5 menit lalu'},
      {id:2, user:'Siti R.', action:'mengedit', file:'Laporan_Keuangan_Q2.xlsx', icon:'edit', bg:'#dcfce7', color:'#16a34a', time:'1 jam lalu'},
      {id:3, user:'Andi P.', action:'membagikan', file:'Proposal_Marketing.pptx', icon:'share-2', bg:'#fef3c7', color:'#d97706', time:'3 jam lalu'},
      {id:4, user:'Dewi L.', action:'menghapus', file:'Draft_Lama.docx', icon:'trash-2', bg:'#fee2e2', color:'#dc2626', time:'Kemarin'},
    ],

    files: [
      {id:1, name:'Kontrak_Kerjasama_2026.pdf', type:'PDF', size:'2.4 MB', date:'16 Jul 2026', icon:'file-text', color:'#ef4444', category:'Hukum'},
      {id:2, name:'Laporan_Keuangan_Q2.xlsx', type:'Spreadsheet', size:'1.8 MB', date:'15 Jul 2026', icon:'table', color:'#10b981', category:'Keuangan'},
      {id:3, name:'Proposal_Marketing.pptx', type:'Dokumen', size:'5.2 MB', date:'14 Jul 2026', icon:'presentation', color:'#f59e0b', category:'Marketing'},
      {id:4, name:'SOP_Onboarding_Karyawan.docx', type:'Dokumen', size:'840 KB', date:'13 Jul 2026', icon:'file-text', color:'#3b82f6', category:'HRD'},
      {id:5, name:'Logo_Perusahaan_v3.png', type:'Gambar', size:'3.1 MB', date:'12 Jul 2026', icon:'image', color:'#8b5cf6', category:'Marketing'},
      {id:6, name:'Invoice_Client_A001.pdf', type:'PDF', size:'420 KB', date:'11 Jul 2026', icon:'file-text', color:'#ef4444', category:'Keuangan'},
      {id:7, name:'Meeting_Notes_Juli.docx', type:'Dokumen', size:'156 KB', date:'10 Jul 2026', icon:'file-text', color:'#3b82f6', category:'Operasional'},
      {id:8, name:'Budget_2026_Final.xlsx', type:'Spreadsheet', size:'2.9 MB', date:'09 Jul 2026', icon:'table', color:'#10b981', category:'Keuangan'},
      {id:9, name:'Brand_Guidelines.pdf', type:'PDF', size:'12 MB', date:'08 Jul 2026', icon:'file-text', color:'#ef4444', category:'Marketing'},
      {id:10, name:'Foto_Team_Building.jpg', type:'Gambar', size:'8.4 MB', date:'07 Jul 2026', icon:'image', color:'#8b5cf6', category:'HRD'},
    ],

    get filteredFiles() {
      return this.files.filter(f => {
        const matchSearch = !this.searchQuery || f.name.toLowerCase().includes(this.searchQuery.toLowerCase());
        const matchType = this.fileType === 'Semua' || f.type === this.fileType;
        const matchCat = !this.filterCategory || f.category === this.filterCategory;
        return matchSearch && matchType && matchCat;
      });
    },

    catColor(name) { return this.categories.find(c=>c.name===name)?.color || '#94a3b8'; },

    init() {
      this.$nextTick(() => lucide.createIcons());
      this.$watch('activeMenu', () => this.$nextTick(() => lucide.createIcons()));
      this.$watch('viewMode', () => this.$nextTick(() => lucide.createIcons()));
      this.$watch('showUpload', () => this.$nextTick(() => lucide.createIcons()));
      this.$watch('previewFile', () => this.$nextTick(() => lucide.createIcons()));
    },

    showToast(msg, type='success') {
      this.toast = {show:true, message:msg, type, icon: type==='success'?'check-circle':'alert-circle'};
      setTimeout(()=>this.toast.show=false, 3000);
      this.$nextTick(() => lucide.createIcons());
    },

    filterFiles() { /* reactivity handles it */ },

    openFile(file) { this.previewFile = file; this.$nextTick(()=>lucide.createIcons()); },
    downloadFile(file) { this.showToast(`Mengunduh ${file.name}...`); },
    shareFile(file) { this.showToast(`Link berbagi ${file.name} disalin`); },
    deleteFile(file) {
      if(confirm(`Hapus ${file.name}?`)) {
        this.files = this.files.filter(f => f.id !== file.id);
        this.showToast(`${file.name} dipindahkan ke sampah`);
      }
    },

    handleUpload(e) {
      const files = Array.from(e.target.files);
      files.forEach(f => {
        this.files.unshift({
          id: Date.now()+Math.random(),
          name: f.name, type: f.type.includes('image')?'Gambar':f.name.endsWith('.pdf')?'PDF':'Dokumen',
          size: (f.size/1024/1024).toFixed(1)+' MB', date: new Date().toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}),
          icon: f.type.includes('image')?'image':'file-text',
          color: f.type.includes('image')?'#8b5cf6':'#3b82f6',
          category: this.uploadCategory
        });
      });
      this.showToast(`${files.length} file berhasil diupload`);
      this.$nextTick(()=>lucide.createIcons());
    },

    uploadLocal() { this.showUpload = false; this.showToast('Upload lokal selesai'); },
    uploadToDrive() {
      if(!this.driveConnected) { this.showToast('Hubungkan Google Drive terlebih dahulu', 'error'); return; }
      this.showUpload = false;
      this.showToast('File diupload ke Google Drive');
    },

    createFolder() {
      if(!this.newFolderName) return;
      this.files.unshift({
        id: Date.now(), name: this.newFolderName, type:'Folder', size:'-',
        date: new Date().toLocaleDateString('id-ID',{day:'2-digit',month:'short',year:'numeric'}),
        icon:'folder', color:'#f59e0b', category:'Operasional'
      });
      this.showToast(`Folder "${this.newFolderName}" dibuat`);
      this.showNewFolder = false;
      this.newFolderName = '';
      this.$nextTick(()=>lucide.createIcons());
    },

    connectDrive() {
      // INTEGRASI GOOGLE DRIVE API
      // 1. Ganti CLIENT_ID & API_KEY dari Google Cloud Console
      // 2. Enable Google Drive API & Google Picker API
      // 3. Uncomment kode di bawah setelah setup OAuth
      /*
      const CLIENT_ID = 'YOUR_CLIENT_ID.apps.googleusercontent.com';
      const API_KEY = 'YOUR_API_KEY';
      const SCOPES = 'https://www.googleapis.com/auth/drive.file';
      
      gapi.load('client:auth2', () => {
        gapi.client.init({apiKey: API_KEY, clientId: CLIENT_ID, scope: SCOPES}).then(() => {
          const auth = gapi.auth2.getAuthInstance();
          if(auth.isSignedIn.get()) {
            this.driveConnected = true;
          } else {
            auth.signIn().then(() => this.driveConnected = true);
          }
        });
      });
      */
      // DEMO MODE
      this.driveConnected = !this.driveConnected;
      this.showToast(this.driveConnected ? 'Google Drive terhubung (Demo)' : 'Drive terputus');
    }
  }
}
</script>
</body>
</html>
